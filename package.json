{
  "name": "tentacles",
  "version": "3.0.0",
  "description": "Tentacles Workbench — recon and bug-hunting platform",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently --names \"API,UI\" --prefix-colors \"cyan,magenta\" \"npm run dev:api\" \"npm run dev:ui\"",
    "start": "node src/server.js",
    "dev:api": "node src/server.js",
    "start:api": "node src/server.js",
    "dev:ui": "cd frontend && npm run dev",
    "start:ui": "cd frontend && npm run preview",
    "build:ui": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "uuid": "^9.0.0",
    "winston": "^3.13.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# TENTACLES WORKBENCH — Environment Configuration
# cp .env.example .env  →  set a password + secrets  →  bash run.sh
# ═══════════════════════════════════════════════════════════════════════════════

# ── Frontend access ───────────────────────────────────────────────────────────
# Set the password the lock screen prompts for. Change this from default!
FRONTEND_PASSWORD=change-this-password

# ── API security ──────────────────────────────────────────────────────────────
# Random string that protects the Tentacles backend API (the /api/* endpoints
# your browser calls — NOT an external service). The lock screen returns this
# to the frontend automatically; you don't type it anywhere.
API_SECRET_KEY=random-string-here-make-it-long
JWT_SECRET=another-random-string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
VPS_PUBLIC_IP=auto

# ── Storage paths (defaults are fine) ─────────────────────────────────────────
WORKBENCH_DIR=/opt/tentacles/workbenches
DEFAULT_CREDENTIALS_PATH=/opt/tentacles/default-credentials.json

# ── Forensic logging (best-effort, can be disabled) ───────────────────────────
FORENSIC_LOG_DIR=/opt/tentacles/forensics
